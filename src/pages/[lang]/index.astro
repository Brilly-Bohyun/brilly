---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PostCard from "../../components/PostCard.astro";
import { getPosts } from "../../lib/blog";
import { labels, site, type Lang, withBase } from "../../lib/site";

export function getStaticPaths() {
  return ["ko", "en"].map((lang) => ({ params: { lang } }));
}

const lang = Astro.params.lang as Lang;
const t = labels[lang];
const posts = await getPosts(lang);
---

<BaseLayout lang={lang} title={site.name} description={site.description}>
  <section class="hero">
    <div>
      <p class="eyebrow">~/brilly/{lang}</p>
      <h1>{site.name}</h1>
      <p class="hero-copy">{site.description}</p>
      <div class="chip-row">
        <a class="chip" href={withBase(`/${lang}/categories/talks/conference/`)}>Open Source Summit</a>
        <a class="chip" href={withBase(`/${lang}/categories/open-source/community/`)}>Open Source</a>
        <a class="chip" href={withBase(`/${lang}/categories/engineering/debugging/`)}>Engineering</a>
      </div>
    </div>
    <img class="hero-mascot" src={withBase("/assets/mascot/brilly-turtle@2x.png")} alt="Brilly turtle mascot" />
  </section>

  <section>
    <div class="section-head">
      <h2>{t.latest}</h2>
      <a href={withBase(`/${lang}/posts/`)}>{t.allPosts}</a>
    </div>
    {posts.length ? (
      <div class="post-grid">
        {posts.slice(0, 6).map((post) => <PostCard post={post} />)}
      </div>
    ) : (
      <div class="empty">
        <div>
          <img src={withBase("/assets/mascot/brilly-turtle.png")} alt="" />
          <p>{t.empty}</p>
        </div>
      </div>
    )}
  </section>
</BaseLayout>
