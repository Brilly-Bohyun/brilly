---
import type { BlogPost } from "../lib/blog";
import { formatDate, postPath } from "../lib/blog";
import { categoryLabel, subcategoryLabel } from "../lib/taxonomy";
import { labels, withBase } from "../lib/site";

const { post } = Astro.props as { post: BlogPost };
const lang = post.data.lang;
const t = labels[lang];
---

<article class="post-card">
  <div class="post-meta">
    <time datetime={post.data.date.toISOString()}>{formatDate(post.data.date, lang)}</time>
    <span>{categoryLabel(post.data.category, lang)} / {subcategoryLabel(post.data.category, post.data.subcategory, lang)}</span>
  </div>
  <h3><a href={withBase(postPath(post))}>{post.data.title}</a></h3>
  <p>{post.data.description}</p>
  <div class="chip-row">
    {post.data.tags.map((tag) => <a class="chip" href={withBase(`/${lang}/tags/${tag}/`)}>{tag}</a>)}
  </div>
  <a class="read-link" href={withBase(postPath(post))}>{t.readMore} →</a>
</article>
