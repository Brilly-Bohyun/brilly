---
import { categoryGroups, getPosts } from "../lib/blog";
import { labels, type Lang, withBase } from "../lib/site";

const { lang } = Astro.props as { lang: Lang };
const t = labels[lang];
const posts = await getPosts(lang);
const pathname = Astro.url.pathname.replace(import.meta.env.BASE_URL.replace(/\/$/, ""), "");
const groups = categoryGroups(posts, lang);
const segments = pathname.split("/").filter(Boolean);
const currentCategory = segments[1] === "categories" ? segments[2] : undefined;
const currentSubcategory = segments[1] === "categories" ? segments[3] : undefined;
---

<aside class="app-sidebar" data-app-sidebar>
  <nav class="sidebar-section" aria-label={t.categories}>
    <p class="sidebar-kicker sidebar-label">{t.categories}</p>
    <div class="sidebar-tree">
      {groups.map(([slug, group]) => (
        <details class="sidebar-category" open={currentCategory === slug || !currentCategory}>
          <summary class={currentCategory === slug && !currentSubcategory ? "is-active" : undefined}>
            <span>{group.label}</span>
            <span class="sidebar-count">{group.count}</span>
          </summary>
          <div class="sidebar-children">
            {[...group.subcategories.entries()].map(([subslug, label]) => (
              <a
                class={`sidebar-subcategory${currentCategory === slug && currentSubcategory === subslug ? " is-active" : ""}`}
                href={withBase(`/${lang}/categories/${slug}/${subslug}/`)}
                aria-current={currentCategory === slug && currentSubcategory === subslug ? "page" : undefined}
              >
                <span>{label}</span>
              </a>
            ))}
          </div>
        </details>
      ))}
    </div>
  </nav>
</aside>
