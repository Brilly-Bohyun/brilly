---
import { labels, otherLang, site, type Lang, withBase } from "../lib/site";

const { lang } = Astro.props as { lang: Lang };
const t = labels[lang];
const alternate = otherLang(lang);
const pathname = Astro.url.pathname.replace(import.meta.env.BASE_URL.replace(/\/$/, ""), "");
const alternatePath = pathname.replace(`/${lang}`, `/${alternate}`);
---

<header class="site-header">
  <nav class="nav" aria-label="Primary">
    <a class="brand" href={withBase(`/${lang}/`)}>
      <img src={withBase("/assets/mascot/brilly-turtle.png")} alt="" width="38" height="38" />
      <span>{site.name}</span>
    </a>
    <div class="nav-links">
      <a href={withBase(`/${lang}/posts/`)}>{t.navPosts}</a>
      <a href={withBase(`/${lang}/categories/`)}>{t.navCategories}</a>
      <a href={withBase(`/${lang}/tags/`)}>{t.navTags}</a>
    </div>
    <button class="nav-button" type="button" data-search-open>{t.search}</button>
    <a class="icon-button" href={withBase(alternatePath || `/${alternate}/`)} aria-label="Switch language">
      {t.language}
    </a>
    <button class="icon-button" type="button" data-theme-toggle aria-label={t.theme}>◐</button>
  </nav>
</header>
