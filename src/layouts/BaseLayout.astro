---
import Header from "../components/Header.astro";
import AppSidebar from "../components/AppSidebar.astro";
import { site, type Lang, withBase } from "../lib/site";
import "../styles/global.css";

const {
  lang,
  title = site.name,
  description = site.description
} = Astro.props as { lang: Lang; title?: string; description?: string };

const pageTitle = title === site.name ? site.name : `${title} | ${site.name}`;
const footer = lang === "ko"
  ? {
      prompt: "bohyun@brilly:~$",
      intro: "회사 소개 대신, 제가 배운 것과 만들고 싶은 것을 남기는 개인 작업실입니다.",
      placeholder: "명령어 입력"
    }
  : {
      prompt: "bohyun@brilly:~$",
      intro: "Less company page, more personal workshop for notes, talks, and things learned in public.",
      placeholder: "type a command"
    };
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <title>{pageTitle}</title>
    <link rel="icon" href={withBase("/favicon.svg")} />
    <script is:inline>
      const saved = localStorage.getItem("brilly-theme");
      const theme = saved || "dark";
      const initialSidebarMedia = matchMedia("(min-width: 1400px)");
      document.documentElement.dataset.theme = theme;
      document.documentElement.dataset.sidebar = initialSidebarMedia.matches
        ? localStorage.getItem("brilly-sidebar") || "expanded"
        : "collapsed";
    </script>
  </head>
  <body>
    <div class="site-shell">
      <AppSidebar lang={lang} />
      <div class="site-pane">
        <Header lang={lang} />
        <main class="main">
          <slot />
        </main>
        <footer class="site-footer">
          <div class="footer-inner">
            <div class="footer-about">
              <img src={withBase("/assets/mascot/brilly-turtle.png")} alt="" width="72" height="72" />
              <div>
                <p class="footer-prompt">{footer.prompt}</p>
                <p>{footer.intro}</p>
                <div class="social-links" aria-label="Social links">
                  <a class="social-icon" href={site.github} aria-label="GitHub" target="_blank" rel="noreferrer">
                    <svg viewBox="0 0 98 96" aria-hidden="true"><path fill="currentColor" d="M48.9 0C21.9 0 0 22 0 49.1c0 21.7 14 40 33.4 46.5 2.4.4 3.3-1.1 3.3-2.4 0-1.2-.1-5.2-.1-9.4-13.6 3-16.5-5.9-16.5-5.9-2.2-5.7-5.4-7.2-5.4-7.2-4.4-3 .3-3 .3-3 4.9.3 7.5 5 7.5 5 4.3 7.4 11.2 5.3 14 4 .4-3.1 1.7-5.3 3-6.5-10.9-1.2-22.3-5.5-22.3-24.3 0-5.4 1.9-9.8 5-13.2-.5-1.2-2.2-6.2.5-13 0 0 4.1-1.3 13.4 5 3.9-1.1 8-1.6 12.1-1.6s8.3.6 12.1 1.6c9.3-6.3 13.4-5 13.4-5 2.7 6.8 1 11.8.5 13 3.1 3.4 5 7.8 5 13.2 0 18.9-11.5 23-22.4 24.2 1.7 1.5 3.3 4.5 3.3 9.1 0 6.5-.1 11.8-.1 13.4 0 1.3.9 2.8 3.4 2.4C83.9 89 98 70.7 98 49.1 98 22 76 0 48.9 0Z" /></svg>
                  </a>
                  <a class="social-icon" href={site.linkedin} aria-label="LinkedIn" target="_blank" rel="noreferrer">
                    <svg viewBox="0 0 24 24" aria-hidden="true"><path fill="currentColor" d="M20.45 20.45h-3.56v-5.57c0-1.33-.03-3.04-1.85-3.04-1.85 0-2.14 1.44-2.14 2.94v5.67H9.34V8.98h3.42v1.56h.05c.48-.9 1.64-1.85 3.37-1.85 3.6 0 4.27 2.37 4.27 5.46v6.3ZM5.32 7.41a2.06 2.06 0 1 1 0-4.12 2.06 2.06 0 0 1 0 4.12Zm1.78 13.04H3.54V8.98H7.1v11.47ZM22.23 0H1.77C.79 0 0 .77 0 1.72v20.56C0 23.23.79 24 1.77 24h20.46c.98 0 1.77-.77 1.77-1.72V1.72C24 .77 23.21 0 22.23 0Z" /></svg>
                  </a>
                </div>
              </div>
            </div>
            <div class="mini-terminal" data-terminal>
              <div class="terminal-bar"><span></span><span></span><span></span></div>
              <div class="terminal-output" data-terminal-output aria-live="polite">
                <div class="terminal-line is-command">
                  <span class="terminal-prompt">$</span>
                  <span class="terminal-command">help</span>
                </div>
                <div class="terminal-line is-muted">available commands</div>
                <div class="terminal-line is-result">whoami        show profile</div>
                <div class="terminal-line is-result">posts         list posts</div>
                <div class="terminal-line is-result">github        show GitHub link</div>
                <div class="terminal-line is-result">linkedin      show LinkedIn link</div>
                <div class="terminal-line is-result">clear         clear terminal</div>
              </div>
              <form class="terminal-input-row" data-terminal-form>
                <span class="terminal-prompt">$</span>
                <input data-terminal-input autocomplete="off" spellcheck="false" aria-label={footer.placeholder} placeholder={footer.placeholder} />
              </form>
            </div>
          </div>
        </footer>
      </div>
    </div>
    <script is:inline>
      const baseUrl = document.querySelector('link[rel="icon"]')?.getAttribute("href")?.replace(/\/favicon\.svg$/, "") || "";
      const sidebarToggle = document.querySelector("[data-sidebar-toggle]");
      const searchShell = document.querySelector("[data-search-shell]");
      const searchPanel = document.querySelector("[data-search-panel]");
      const form = document.querySelector("[data-search-form]");
      const input = document.querySelector("[data-search-input]");
      const clearSearch = document.querySelector("[data-search-clear]");
      const filterButtons = document.querySelectorAll("[data-search-filter]");
      const results = document.querySelector("[data-search-results]");
      let selectedFilter = { key: "", value: "" };
      let pagefind;

      const sidebarMedia = matchMedia("(min-width: 1400px)");
      const savedSidebar = () => (sidebarMedia.matches ? localStorage.getItem("brilly-sidebar") || "expanded" : "collapsed");
      const setSidebar = (state, persist = sidebarMedia.matches) => {
        document.documentElement.dataset.sidebar = state;
        if (persist) localStorage.setItem("brilly-sidebar", state);
        sidebarToggle?.setAttribute("aria-expanded", state === "expanded" ? "true" : "false");
        sidebarToggle?.setAttribute(
          "aria-label",
          state === "expanded"
            ? sidebarToggle.dataset.collapseLabel || ""
            : sidebarToggle.dataset.expandLabel || ""
        );
      };

      setSidebar(savedSidebar(), false);
      sidebarMedia.addEventListener("change", () => setSidebar(savedSidebar(), false));
      sidebarToggle?.addEventListener("click", () => {
        setSidebar(document.documentElement.dataset.sidebar === "collapsed" ? "expanded" : "collapsed", sidebarMedia.matches);
      });

      form?.addEventListener("submit", (event) => event.preventDefault());

      const setSearchOpen = (open) => {
        if (!searchPanel || !searchShell) return;
        searchPanel.hidden = !open;
        searchShell.classList.toggle("is-open", open);
      };

      const syncClearButton = () => {
        if (!input || !clearSearch || !searchShell) return;
        const hasQuery = Boolean(input.value);
        clearSearch.hidden = !hasQuery;
        searchShell.classList.toggle("has-query", hasQuery);
      };

      filterButtons.forEach((button) => {
        button.addEventListener("click", () => {
          const key = button.dataset.filterKey || "";
          const value = button.dataset.filterValue || "";
          const isSame = selectedFilter.key === key && selectedFilter.value === value;
          selectedFilter = isSame ? { key: "", value: "" } : { key, value };
          filterButtons.forEach((item) => {
            const active = item.dataset.filterKey === selectedFilter.key && item.dataset.filterValue === selectedFilter.value;
            item.classList.toggle("is-active", active);
            item.setAttribute("aria-pressed", active ? "true" : "false");
          });
          runSearch();
        });
      });

      const runSearch = async () => {
        const query = input?.value.trim() || "";
        syncClearButton();
        if (!results) return;
        if (!query) {
          results.innerHTML = "";
          results.hidden = true;
          return;
        }

        try {
          pagefind ||= await import(`${baseUrl}/pagefind/pagefind.js`);
          const options = selectedFilter.value ? { filters: { [selectedFilter.key]: [selectedFilter.value] } } : {};
          const search = await pagefind.search(query, options);
          const items = await Promise.all(search.results.slice(0, 8).map((result) => result.data()));
          results.innerHTML = items.length
            ? items
                .map(
                  (item) => `<a class="search-result" href="${item.url}"><strong>${item.meta.title || item.excerpt}</strong><small>${item.excerpt}</small></a>`
                )
                .join("")
            : `<div class="search-empty">${searchShell?.dataset.noResults || "No results."}</div>`;
          results.hidden = false;
        } catch {
          results.innerHTML = `<div class="search-empty">Search index is available after build.</div>`;
          results.hidden = false;
        }
      };

      syncClearButton();
      input?.addEventListener("focus", () => setSearchOpen(true));
      input?.addEventListener("input", runSearch);
      clearSearch?.addEventListener("click", () => {
        if (!input || !results) return;
        input.value = "";
        results.innerHTML = "";
        results.hidden = true;
        syncClearButton();
        setSearchOpen(true);
        input.focus();
      });
      document.addEventListener("click", (event) => {
        if (!searchShell?.contains(event.target)) setSearchOpen(false);
      });

      const setGiscusTheme = (theme) => {
        const frame = document.querySelector("iframe.giscus-frame");
        if (!frame) return;
        frame.contentWindow?.postMessage(
          { giscus: { setConfig: { theme: theme === "dark" ? "noborder_dark" : "noborder_light" } } },
          "https://giscus.app"
        );
      };

      document.querySelector("[data-theme-toggle]")?.addEventListener("click", () => {
        const next = document.documentElement.dataset.theme === "dark" ? "light" : "dark";
        document.documentElement.dataset.theme = next;
        localStorage.setItem("brilly-theme", next);
        setGiscusTheme(next);
      });

      document.querySelectorAll("[data-like-button]").forEach((button) => {
        const key = `brilly-like:${button.dataset.postKey}`;
        const render = () => {
          const liked = localStorage.getItem(key) === "1";
          button.classList.toggle("is-active", liked);
        };
        render();
        button.addEventListener("click", () => {
          localStorage.setItem(key, localStorage.getItem(key) === "1" ? "0" : "1");
          render();
        });
      });

      document.querySelectorAll("[data-share-button]").forEach((button) => {
        button.addEventListener("click", async () => {
          const share = { title: button.dataset.shareTitle || document.title, url: location.href };
          if (navigator.share) await navigator.share(share);
          else await navigator.clipboard?.writeText(location.href);
        });
      });

      const terminal = document.querySelector("[data-terminal]");
      const terminalOutput = terminal?.querySelector("[data-terminal-output]");
      const terminalForm = terminal?.querySelector("[data-terminal-form]");
      const terminalInput = terminal?.querySelector("[data-terminal-input]");
      const terminalResponses = {
        help: ["commands: whoami, posts, github, linkedin, clear"],
        whoami: ["Bohyun Choi", "Open source, systems, talks, developer experience."],
        posts: ["starting-tech-blog.md", "opensource-summit-us-talk.md"],
        github: ["https://github.com/Brilly-Bohyun"],
        linkedin: ["https://www.linkedin.com/in/bohyunchoi/"]
      };
      const terminalAliases = {
        "open github": "github",
        "open linkedin": "linkedin"
      };

      const appendTerminalLine = (kind, text, command = false) => {
        if (!terminalOutput) return;
        const line = document.createElement("div");
        line.className = `terminal-line ${kind}`;
        if (command) {
          const prompt = document.createElement("span");
          prompt.className = "terminal-prompt";
          prompt.textContent = "$";
          const value = document.createElement("span");
          value.className = "terminal-command";
          value.textContent = text;
          line.append(prompt, value);
        } else {
          line.textContent = text;
        }
        terminalOutput.append(line);
        terminalOutput.scrollTop = terminalOutput.scrollHeight;
      };

      const runTerminalCommand = (raw) => {
        const command = raw.trim();
        if (!command || !terminalOutput) return;
        if (command.toLowerCase() === "clear") {
          terminalOutput.textContent = "";
          return;
        }
        appendTerminalLine("is-command", command, true);
        const key = terminalAliases[command.toLowerCase()] || command.toLowerCase();
        const response = terminalResponses[key];
        if (!response) {
          appendTerminalLine("is-error", `command not found: ${command}`);
          appendTerminalLine("is-muted", 'try "help"');
          return;
        }
        response.forEach((line) => appendTerminalLine("is-result", line));
      };

      terminalForm?.addEventListener("submit", (event) => {
        event.preventDefault();
        if (!terminalInput) return;
        runTerminalCommand(terminalInput.value);
        terminalInput.value = "";
      });
    </script>
  </body>
</html>
